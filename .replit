modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["zip"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[[ports]]
localPort = 23636
externalPort = 3002

[[ports]]
localPort = 23637
externalPort = 3001

[[ports]]
localPort = 23638
externalPort = 3003

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy: daily-challenge"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy: media-search"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy: post-scheduled-content"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy: generate-persona-content"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy: social-feed"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy: generate-trivia-polls"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy: generate-dna-moments"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Deploy: daily-challenge"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx supabase functions deploy daily-challenge --project-ref mahpgcogwpawvviapqza --use-api"

[workflows.workflow.metadata]
outputType = "console"

